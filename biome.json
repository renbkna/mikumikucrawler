{
	"$schema": "https://biomejs.dev/schemas/2.4.2/schema.json",
	"vcs": {
		"enabled": true,
		"clientKind": "git",
		"useIgnoreFile": true
	},
	"files": {
		"ignoreUnknown": true,
		"includes": [
			"**/*.ts",
			"**/*.tsx",
			"**/*.js",
			"**/*.jsx",
			"**/*.json",
			"**/*.css"
		]
	},
	"formatter": {
		"enabled": true,
		"indentStyle": "tab",
		"indentWidth": 2
	},
	"linter": {
		"enabled": true,
		"rules": {
			"recommended": true,
			"correctness": {
				"recommended": true,
				"useExhaustiveDependencies": "error",
				"useHookAtTopLevel": "error",
				"noUnusedVariables": "error",
				"noUnusedImports": "error",
				"noUnreachable": "error",
				"noUndeclaredVariables": "error"
			},
			"a11y": {
				"recommended": true
			},
			"style": {
				"recommended": true,
				"noNonNullAssertion": "error",
				"useConst": "error",
				"useTemplate": "error",
				"noParameterAssign": "error"
			},
			"suspicious": {
				"recommended": true,
				"noExplicitAny": "error",
				"noConsole": "warn",
				"noDoubleEquals": "error"
			},
			"complexity": {
				"recommended": true,
				"noForEach": "warn"
			},
			"performance": {
				"recommended": true,
				"noDelete": "warn"
			},
			"security": {
				"recommended": true,
				"noDangerouslySetInnerHtml": "error",
				"noGlobalEval": "error"
			}
		}
	},
	"javascript": {
		"formatter": {
			"quoteStyle": "double",
			"trailingCommas": "all"
		},
		"globals": ["Bun"]
	},
	"css": {
		"parser": {
			"cssModules": true,
			"tailwindDirectives": true
		}
	},
	"assist": {
		"actions": {
			"source": {
				"organizeImports": {
					"level": "on"
				}
			}
		}
	}
}

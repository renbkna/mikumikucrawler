{
	"name": "miku-miku-crawler",
	"private": true,
	"version": "3.0.0",
	"type": "module",
	"author": {
		"name": "renbkna",
		"url": "https://github.com/renbkna"
	},
	"scripts": {
		"dev": "concurrently --ks SIGKILL -n \"Client,Server\" \"npm run dev:client\" \"npm run dev:server\"",
		"dev:server": "bun --watch server/server.ts",
		"dev:client": "vite",
		"build": "vite build",
		"lint": "biome check . && oxlint",
		"lint:biome": "biome check .",
		"lint:ox": "oxlint",
		"format": "biome format . --write",
		"preview": "vite preview",
		"start": "bun server/server.ts",
		"test": "bun test",
		"profile:cpu": "bun run --cpu-prof server/server.ts",
		"profile:heap": "bun run --heap-prof-md server/server.ts"
	},
	"dependencies": {
		"@elysiajs/cors": "^1.4.1",
		"@elysiajs/eden": "^1.4.8",
		"@elysiajs/static": "^1.4.7",
		"@elysiajs/swagger": "^1.3.1",
		"cheerio": "^1.2.0",
		"concurrently": "^9.2.1",
		"dompurify": "^3.3.1",
		"elysia": "^1.4.25",
		"elysia-rate-limit": "^4.5.0",
		"franc": "^6.2.0",
		"lucide-react": "^0.564.0",
		"pdf-parse": "^2.4.5",
		"pino": "^10.3.1",
		"pino-pretty": "^13.1.3",
		"puppeteer": "^24.37.3",
		"react": "^19.2.4",
		"react-dom": "^19.2.4",
		"react-virtuoso": "^4.18.1",
		"sanitize-html": "^2.17.0",
		"sentiment": "^5.0.2"
	},
	"devDependencies": {
		"@biomejs/biome": "2.4.2",
		"@tailwindcss/vite": "^4.1.18",
		"@types/bun": "^1.3.9",
		"@types/dompurify": "^3.0.5",
		"@types/react": "^19.2.14",
		"@types/react-dom": "^19.2.3",
		"@types/sanitize-html": "^2.16.0",
		"@vitejs/plugin-react": "^5.1.4",
		"oxlint": "^0.15.0",
		"tailwindcss": "^4.1.18",
		"typescript": "^5.9.3",
		"vite": "^7.3.1"
	}
}

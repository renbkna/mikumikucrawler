{
	"name": "miku-miku-crawler",
	"private": true,
	"version": "3.0.0",
	"type": "module",
	"author": {
		"name": "renbkna",
		"url": "https://github.com/renbkna"
	},
	"scripts": {
		"prepare": "lefthook install --force",
		"dev": "concurrently --ks SIGKILL -n \"Client,Server\" \"npm run dev:client\" \"npm run dev:server\"",
		"dev:server": "bun --watch server/server.ts",
		"dev:client": "vite",
		"build": "vite build",
		"check": "bun run format:check && bun run lint && bun run lint:type-aware && bun run typecheck && bun test && bun run build",
		"format:check": "biome format --files-ignore-unknown=true server shared src docs package.json tsconfig.json tsconfig.server.json vite.config.ts biome.json README.md .oxlintrc.json",
		"format": "biome format --write --files-ignore-unknown=true server shared src docs package.json tsconfig.json tsconfig.server.json vite.config.ts biome.json README.md .oxlintrc.json",
		"lint": "oxlint --config .oxlintrc.json --deny-warnings server shared src vite.config.ts",
		"lint:type-aware": "oxlint --config .oxlintrc.json --type-aware --deny-warnings server shared src vite.config.ts",
		"preview": "vite preview",
		"start": "bun server/server.ts",
		"test": "bun test",
		"typecheck": "tsc -p tsconfig.json --noEmit && tsc -p tsconfig.server.json --noEmit"
	},
	"dependencies": {
		"@elysiajs/cors": "^1.4.1",
		"@elysiajs/eden": "^1.4.8",
		"@elysiajs/openapi": "^1.4.14",
		"@elysiajs/opentelemetry": "^1.4.10",
		"@elysiajs/server-timing": "^1.4.0",
		"cheerio": "^1.2.0",
		"concurrently": "^9.2.1",
		"crawlee": "^3.16.0",
		"dompurify": "^3.3.3",
		"elysia": "^1.4.28",
		"elysia-rate-limit": "^4.5.1",
		"franc": "^6.2.0",
		"ipaddr.js": "^2.3.0",
		"lucide-react": "^0.577.0",
		"pdfjs-dist": "^5.5.207",
		"pino": "^10.3.1",
		"pino-pretty": "^13.1.3",
		"playwright": "^1.58.2",
		"react": "^19.2.4",
		"react-dom": "^19.2.4",
		"react-virtuoso": "^4.18.3",
		"tldts": "^7.0.27"
	},
	"devDependencies": {
		"@biomejs/biome": "2.4.8",
		"@tailwindcss/vite": "^4.2.2",
		"@types/bun": "^1.3.11",
		"@types/dompurify": "^3.0.5",
		"@types/react": "^19.2.14",
		"@types/react-dom": "^19.2.3",
		"@vitejs/plugin-react": "^6.0.1",
		"lefthook": "^2.1.4",
		"oxlint": "^1.56.0",
		"tailwindcss": "^4.2.2",
		"typescript": "^5.9.3",
		"vite": "^8.0.1"
	}
}

{
	"name": "miku-miku-crawler",
	"version": "3.0.0",
	"private": true,
	"type": "module",
	"packageManager": "bun@1.3.14",
	"workspaces": {
		"packages": [],
		"catalog": {
			"@types/bun": "1.3.14",
			"@biomejs/biome": "2.5.0",
			"@typescript/native-preview": "^7.0.0-dev.20260620.1"
		}
	},
	"author": {
		"name": "renbkna",
		"url": "https://github.com/renbkna"
	},
	"scripts": {
		"prepare": "bun scripts/install-git-hooks.ts",
		"hooks:install": "lefthook install --force",
		"dev": "concurrently --kill-others-on-fail --kill-signal SIGTERM -n \"Client,Server\" \"bun run dev:client\" \"bun run dev:server\"",
		"dev:server": "bun --watch server/server.ts",
		"dev:client": "vite",
		"build": "vite build",
		"check": "bun run typecheck && bun run lint && bun test && bun run build",
		"typecheck": "tsgo -b --pretty false --checkers 4 --builders 2",
		"typecheck:single": "tsgo -b --pretty false --singleThreaded",
		"format": "biome check --write .",
		"format:check": "biome format .",
		"lint": "biome ci .",
		"fix": "biome check --write .",
		"fix:unsafe": "biome check --write --unsafe .",
		"preview": "vite preview",
		"start": "bun server/server.ts",
		"test": "bun test",
		"clean": "rm -rf dist coverage node_modules/.tmp"
	},
	"dependencies": {
		"@elysiajs/cors": "^1.4.1",
		"@elysiajs/eden": "^1.4.8",
		"@elysiajs/openapi": "^1.4.14",
		"@elysiajs/opentelemetry": "^1.4.10",
		"@elysiajs/server-timing": "^1.4.0",
		"@sinclair/typebox": "^0.34.49",
		"cheerio": "^1.2.0",
		"crawlee": "^3.16.0",
		"domhandler": "^6.0.1",
		"elysia": "^1.4.28",
		"elysia-rate-limit": "^4.5.1",
		"franc": "^6.2.0",
		"ipaddr.js": "^2.3.0",
		"lucide-react": "^1.14.0",
		"pdfjs-dist": "^5.5.207",
		"pino": "^10.3.1",
		"pino-pretty": "^13.1.3",
		"playwright": "^1.58.2",
		"react": "^19.2.4",
		"react-dom": "^19.2.4",
		"react-virtuoso": "^4.18.3",
		"tldts": "^7.0.27"
	},
	"devDependencies": {
		"@biomejs/biome": "catalog:",
		"@tailwindcss/vite": "^4.2.2",
		"@types/bun": "catalog:",
		"@types/react": "^19.2.14",
		"@types/react-dom": "^19.2.3",
		"@typescript/native-preview": "catalog:",
		"@vitejs/plugin-react": "^6.0.1",
		"concurrently": "^9.2.1",
		"lefthook": "^2.1.4",
		"tailwindcss": "^4.2.2",
		"vite": "^8.0.10"
	}
}

{
	"name": "miku-miku-crawler",
	"version": "3.0.0",
	"private": true,
	"type": "module",
	"packageManager": "bun@1.3.14",
	"author": {
		"name": "renbkna",
		"url": "https://github.com/renbkna"
	},
	"overrides": {
		"brace-expansion": "2.0.3",
		"file-type": "21.3.4",
		"ip-address": "10.2.0",
		"undici": "7.28.0"
	},
	"scripts": {
		"prepare": "bun scripts/install-git-hooks.ts",
		"hooks:install": "lefthook install --force",
		"dev": "bun scripts/dev.ts",
		"dev:server": "bun --watch server/server.ts",
		"dev:client": "bun --bun vite",
		"build": "bun --bun vite build",
		"check": "bun run typecheck && bun run lint && bun test && bun run build",
		"typecheck": "tsgo -b --pretty false",
		"format": "biome format --write .",
		"format:check": "biome format .",
		"lint": "biome ci .",
		"fix": "biome check --write .",
		"fix:unsafe": "biome check --write --unsafe .",
		"preview": "bun --bun vite preview",
		"start": "bun server/server.ts",
		"test": "bun test",
		"clean": "rm -rf dist coverage node_modules/.tmp"
	},
	"dependencies": {
		"@crawlee/browser-pool": "^3.17.0",
		"@crawlee/core": "^3.17.0",
		"@elysiajs/cors": "^1.4.2",
		"@elysiajs/eden": "^1.4.9",
		"@elysiajs/openapi": "^1.4.15",
		"@elysiajs/server-timing": "^1.4.1",
		"@elysiajs/static": "^1.4.10",
		"@sinclair/typebox": "^0.34.52",
		"cheerio": "^1.2.0",
		"domhandler": "^6.0.1",
		"elysia": "^1.4.29",
		"elysia-rate-limit": "^4.6.2",
		"exact-mirror": "^0.2.7",
		"file-type": "^21.3.4",
		"franc": "^6.2.0",
		"ipaddr.js": "^2.4.0",
		"lru-cache": "^11.5.2",
		"lucide-react": "^1.24.0",
		"openapi-types": "^12.1.3",
		"pdfjs-dist": "^6.1.200",
		"pino": "^10.3.1",
		"playwright": "^1.61.1",
		"react": "^19.2.7",
		"react-dom": "^19.2.7",
		"react-virtuoso": "^4.18.10",
		"robots-parser": "^3.0.1",
		"tldts": "^7.4.9"
	},
	"devDependencies": {
		"@biomejs/biome": "2.5.0",
		"@tailwindcss/vite": "^4.3.3",
		"@types/bun": "^1.3.14",
		"@types/react": "^19.2.17",
		"@types/react-dom": "^19.2.3",
		"@typescript/native-preview": "^7.0.0-dev.20260707.2",
		"@vitejs/plugin-react": "^6.0.3",
		"concurrently": "^10.0.3",
		"lefthook": "^2.1.10",
		"pino-pretty": "^13.1.3",
		"tailwindcss": "^4.3.3",
		"vite": "^8.1.5"
	},
	"patchedDependencies": {
		"elysia-rate-limit@4.6.2": "patches/elysia-rate-limit@4.6.2.patch"
	}
}

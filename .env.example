# ==============================================================================
# Miku Miku Crawler - Environment Configuration (v3.0.0)
# ==============================================================================
# Instructions:
# 1. Rename this file to .env
# 2. Update the values below to match your environment.
# 3. Backend variables are loaded by Bun/Node.
# 4. Frontend variables (VITE_) are injected into the client-side bundle.

# ------------------------------------------------------------------------------
# 1. Core Server Settings
# ------------------------------------------------------------------------------
# 'production' enables high-performance JSON logging and optimized library modes.
NODE_ENV=development

# The port the backend server will listen on.
PORT=3000

# ------------------------------------------------------------------------------
# 2. Cross-Origin Resource Sharing (CORS)
# ------------------------------------------------------------------------------
# The exact URL where your frontend is hosted. This is the sole admitted
# production origin. Development additionally admits localhost, 127.0.0.1,
# and [::1] browser origins on any port so Vite can select a free port.
FRONTEND_URL=http://localhost:5173

# ------------------------------------------------------------------------------
# 3. Frontend Connectivity (VITE_ Prefix Required)
# ------------------------------------------------------------------------------
# The base URL for HTTP commands and SSE crawl events.
VITE_BACKEND_URL=http://localhost:3000

# ------------------------------------------------------------------------------
# 4. Data Storage & Logging
# ------------------------------------------------------------------------------
# Relative or absolute path to your SQLite database.
DB_PATH=./data/crawler.db

# Log level: trace, debug, info, warn, error, fatal
LOG_LEVEL=info

# The identification string sent in HTTP requests.
USER_AGENT=MikuCrawler/3.0.0

# RFC robots.txt product token. Required when USER_AGENT is a detailed string
# rather than one product token with an optional version.
ROBOTS_PRODUCT_TOKEN=MikuCrawler

# ------------------------------------------------------------------------------
# 4. Performance & Platform
# ------------------------------------------------------------------------------
# Enables Render-owned client-IP forwarding, Render-specific browser recycling,
# and a conservative default browser RSS threshold of 350MB (600MB elsewhere).
RENDER=false

# Dynamic rendering is skipped only when process RSS exceeds this threshold.
# MEMORY_THRESHOLD_MB=600

# ------------------------------------------------------------------------------
# 5. Playwright / Chromium (Custom Deployments)
# ------------------------------------------------------------------------------
# The repository Docker image installs Playwright's matching Chromium build and
# needs no override. Local development also discovers common Chromium commands
# on PATH. For a custom system-browser deployment, set its executable explicitly.
# PLAYWRIGHT_CHROMIUM_EXECUTABLE_PATH=/usr/bin/chromium

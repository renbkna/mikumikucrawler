# ==============================================================================
# Miku Miku Crawler - Environment Configuration (v3.0.0)
# ==============================================================================
# Instructions:
# 1. Rename this file to .env
# 2. Update the values below to match your environment.
# 3. Backend variables are loaded by Bun/Node.
# 4. Frontend variables (VITE_) are injected into the client-side bundle.

# ------------------------------------------------------------------------------
# 1. Core Server Settings
# ------------------------------------------------------------------------------
# 'production' enables high-performance JSON logging and optimized library modes.
NODE_ENV=development

# The port the backend server will listen on.
PORT=3000

# ------------------------------------------------------------------------------
# 2. Cross-Origin Resource Sharing (CORS)
# ------------------------------------------------------------------------------
# The exact URL where your frontend is hosted. This allows the frontend
# to communicate with the backend API.
FRONTEND_URL=http://localhost:5173

# ------------------------------------------------------------------------------
# 3. Frontend Connectivity (VITE_ Prefix Required)
# ------------------------------------------------------------------------------
# The base URL for HTTP commands and SSE crawl events.
VITE_BACKEND_URL=http://localhost:3000

# ------------------------------------------------------------------------------
# 4. Data Storage & Logging
# ------------------------------------------------------------------------------
# Relative or absolute path to your SQLite database.
DB_PATH=./data/crawler.db

# Log level: trace, debug, info, warn, error, fatal
LOG_LEVEL=info

# The User-Agent string used for HTTP requests and robots.txt compliance.
USER_AGENT=MikuCrawler/3.0.0

# ------------------------------------------------------------------------------
# 4. Performance & Platform
# ------------------------------------------------------------------------------
# Set to 'true' to enable 'Constrained Memory Mode'.
# Recommended for Render.com, Heroku, or servers with < 1GB RAM.
RENDER=false

# ------------------------------------------------------------------------------
# 5. Playwright / Chromium (Custom Deployments)
# ------------------------------------------------------------------------------
# The repository Docker image installs Playwright's matching Chromium build and
# needs no override. For a custom system-browser deployment, set its executable.
# PLAYWRIGHT_CHROMIUM_EXECUTABLE_PATH=/usr/bin/chromium

{
	"extends": "./tsconfig.base.json",
	"compilerOptions": {
		"composite": true,
		"rootDir": ".",
		"tsBuildInfoFile": "./node_modules/.tmp/tsconfig.server.tsbuildinfo",
		"outDir": "./dist",
		"module": "nodenext",
		"moduleResolution": "nodenext",
		"lib": ["ESNext", "DOM"],
		"types": ["bun"],
		"noEmit": true
	},
	"include": ["server/**/*", "shared/**/*"],
	"exclude": ["shared/__tests__/**/*", "shared/__tests__"]
}

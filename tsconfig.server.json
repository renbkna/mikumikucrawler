{
	"compilerOptions": {
		"target": "ESNext",
		"module": "nodenext",
		"moduleResolution": "nodenext",
		"lib": ["ESNext", "DOM"],
		"outDir": "./dist",
		"strict": true,
		"esModuleInterop": true,
		"skipLibCheck": true,
		"forceConsistentCasingInFileNames": true,
		"noEmit": true,
		"allowJs": true,
		"checkJs": false,
		"types": ["bun"]
	},
	"include": ["server/**/*", "server/types/**/*.d.ts"]
}
